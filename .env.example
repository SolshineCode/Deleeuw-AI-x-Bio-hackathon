# Required for judge consortium (both used by GeminiJudge / ClaudeHaikuJudge)
GEMINI_API_KEY=
# Optional -- if unset, Claude judging falls back to `claude -p` subprocess (Claude Code credits)
ANTHROPIC_API_KEY=
# Required for Gemma 3 family weights (HF-gated)
HF_TOKEN=
# Optional -- tertiary judge via OpenRouter
OPENROUTER_API_KEY=
